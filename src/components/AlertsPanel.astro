---
// src/components/AlertsPanel.astro
---
<div class="absolute top-20 right-4 md:top-24 md:right-6 z-[60] flex flex-col items-end pointer-events-none">
  <button id="alerts-toggle" class="pointer-events-auto p-4 bg-slate-900/90 backdrop-blur-xl border border-rose-500/30 rounded-2xl text-rose-400 shadow-[0_0_20px_rgba(244,63,94,0.2)] hover:scale-105 active:scale-95 transition-all relative">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
    </svg>
    <span id="alerts-badge" class="hidden absolute -top-1 -right-1 w-5 h-5 bg-rose-600 text-white text-[10px] font-black rounded-full flex items-center justify-center border-2 border-slate-900 shadow-lg">0</span>
  </button>

  <div id="alerts-panel" class="hidden pointer-events-auto mt-3 w-72 backdrop-blur-2xl bg-slate-950/90 border border-rose-500/10 rounded-3xl shadow-2xl p-4 flex flex-col gap-3 animate-slideLeft origin-top-right">
    <div class="flex justify-between items-center mb-1">
      <h3 class="text-xs font-black text-rose-400 uppercase tracking-widest">Alertas de Ciudad</h3>
      <span class="text-[9px] text-slate-500 font-mono">Real-time</span>
    </div>
    <div id="side-alerts-box" class="space-y-3 max-h-[60vh] overflow-y-auto pr-1">
       <!-- Active reports will bounce here -->
    </div>
  </div>
</div>
