---
// src/components/ToolsPanel.astro
const { transports } = Astro.props;
---
<aside id="main-panel" class="absolute bottom-0 left-0 md:top-24 md:left-6 z-50 w-full md:w-[340px] pointer-events-none p-4 md:p-0 transition-all duration-500 transform translate-y-full md:translate-y-0 md:-translate-x-[120%] opacity-0">
  <div class="pointer-events-auto backdrop-blur-2xl bg-slate-950/90 border border-white/10 rounded-t-3xl md:rounded-3xl shadow-[0_0_50px_rgba(0,0,0,0.5)] overflow-hidden flex flex-col max-h-[70vh] md:max-h-[calc(100vh-140px)]">
    
    <!-- Tabs Buttons -->
    <!-- Tabs Buttons -->
    <nav class="flex border-b border-white/5 bg-slate-950/50 p-1">
      <button id="tab-btn-predict" class="flex-1 py-3 text-[10px] font-black uppercase tracking-tighter text-white transition-all bg-blue-600/20 rounded-xl" data-tab="predict">
        🔮 Afluencia
      </button>
      <button id="tab-btn-layers" class="flex-1 py-3 text-[10px] font-black uppercase tracking-tighter text-slate-500 hover:text-white transition-all rounded-xl" data-tab="layers">
        🗺️ Capas
      </button>
    </nav>

    <!-- Dynamic Content -->
    <div id="tab-content" class="p-5 flex-1 overflow-y-auto">
      <!-- TAB: PREDICT -->
      <div id="pane-predict" class="tab-pane space-y-4">
        <h3 class="text-xs font-black text-cyan-400 uppercase tracking-widest">Predicción de Afluencia</h3>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-2">
            <div class="space-y-1">
              <label class="text-[9px] font-bold text-slate-500 uppercase ml-1">Sistema</label>
              <select id="sel-predict-system" class="w-full bg-slate-950 border border-slate-800 rounded-lg px-2 py-2 text-xs text-white outline-none h-[34px]">
                <option value="metro">Metro</option>
                <option value="metrobus">Metrobús</option>
                <option value="cablebus">Cablebús</option>
                <option value="trolebus">Trolebús</option>
                <option value="rtp">RTP</option>
                <option value="tren_ligero">Tren Ligero</option>
                <option value="ecobici">Ecobici</option>
              </select>
            </div>
            <div class="space-y-1">
              <label class="text-[9px] font-bold text-slate-500 uppercase ml-1">Línea</label>
              <input id="in-predict-line" type="text" placeholder="Línea" readonly class="w-full bg-slate-950/50 border border-slate-800/50 rounded-lg px-2 py-2 text-xs text-slate-500 outline-none cursor-not-allowed" />
            </div>
          </div>
          <div class="relative">
            <label class="text-[9px] font-bold text-slate-500 uppercase ml-1">Estación</label>
            <input id="in-predict-station" type="text" autocomplete="off" placeholder="Busca estación..." class="w-full bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-sm text-white focus:border-cyan-500 outline-none" />
            <ul id="autocomplete-list" class="hidden absolute top-full left-0 w-full bg-slate-900 border border-slate-800 rounded-lg mt-1 z-[60] max-h-40 overflow-y-auto overflow-x-hidden shadow-2xl"></ul>
          </div>
          <button id="btn-run-predict" class="w-full py-4 bg-cyan-600 hover:bg-cyan-500 text-white font-black rounded-xl transition-all shadow-lg shadow-cyan-600/30 uppercase tracking-widest text-xs">
            Analizar Ocupación
          </button>

          <div id="predict-result-box" class="hidden p-5 bg-slate-950/80 rounded-2xl border border-white/5 flex flex-col items-center gap-3 animate-slideUp">
            <div class="relative w-24 h-24">
              <svg class="w-full h-full transform -rotate-90">
                <circle cx="48" cy="48" r="42" stroke="currentColor" stroke-width="6" fill="transparent" class="text-slate-800" />
                <circle id="gauge-circle" cx="48" cy="48" r="42" stroke="currentColor" stroke-width="7" fill="transparent" stroke-dasharray="264" stroke-dashoffset="264" stroke-linecap="round" class="text-cyan-500 transition-all duration-1000" />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span id="out-perc" class="text-xl font-black text-white">0%</span>
              </div>
            </div>
            <div class="text-center">
              <p id="out-label" class="text-xs font-black text-cyan-300 uppercase tracking-tighter">--</p>
              <p id="out-sys" class="text-[9px] text-slate-500 italic mt-0.5">--</p>
            </div>
          </div>
        </div>
      </div>

      <!-- TAB: LAYERS -->
      <div id="pane-layers" class="tab-pane hidden space-y-4">
        <h3 class="text-xs font-black text-amber-400 uppercase tracking-widest">Capas de Infraestructura</h3>
        <div class="grid grid-cols-1 gap-2">
          {transports.map((t) => (
            <button data-transport={t.id} data-color={t.color} data-lines={t.lines.toString()} data-stations={t.stations.toString()} class="layer-toggle flex items-center justify-between p-3 rounded-xl border border-white/5 bg-slate-950/40 hover:bg-slate-800/50 transition-all group">
              <div class="flex items-center gap-3">
                <div class={`w-3 h-3 rounded-full ${t.hexBg} opacity-40 group-hover:opacity-100 indicator-dot transition-all shadow-[0_0_0px_white]`}></div>
                <span class="text-[11px] font-bold text-slate-300 group-hover:text-white uppercase tracking-tighter">{t.name}</span>
              </div>
              <div class="status-icon text-slate-600 group-hover:text-amber-400 transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
              </div>
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Footer Insight -->
    <footer class="p-3 bg-slate-950/80 border-t border-white/5 text-[9px] text-slate-500 font-medium italic flex items-center gap-2">
      <svg class="w-3 h-3 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2"/></svg>
      Urban Copilot AI: Analizando red de transporte CDMX...
    </footer>
  </div>
</aside>
